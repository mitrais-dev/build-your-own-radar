# Frontend-only Static Configuration
# No backend server needed - all fetches use free CORS proxy

# Set to 'true' (default) to route all fetches through the selected CORS proxy
# Set to 'false' to disable the CORS proxy (may cause CORS errors with Google Sheets/OneDrive)
USE_CORS_PROXY=true

# CORS Proxy Selection
# Options: 'local', 'allorigins' (recommended), 'corsanywhere', 'corsninja'
CORS_PROXY=allorigins

# Local Express proxy URL template (used when CORS_PROXY=local)
# The target URL will be appended as encoded query string value
CORS_PROXY_LOCAL_URL=http://localhost:8787/proxy?url=

# Base URL used by XMLHttpRequest validation in sheet.js
# For local proxy usage, set this to: http://localhost:8787/proxy?url=https%3A%2F%2Fdocs.google.com%2Fspreadsheets%2Fd%2F
SHEET_VALIDATE_URL=https://docs.google.com/spreadsheets/d/

# Radar Data Configuration
# Set to 'true' to allow public URLs (OneDrive/Google Sheets) from query params
# Set to 'false' to only use the configured RADAR_DATA_URL below
ALLOW_PUBLIC_URLS=true

# Default radar data source (OneDrive, Google Sheets, or local file URL)
# Used when ALLOW_PUBLIC_URLS=false or when no URL is provided in query params
RADAR_DATA_URL=
